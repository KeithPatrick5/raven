# Optional. If set, Raven requires this passcode before showing the dashboard.
RAVEN_ACCESS_KEY=change-this-private-code

# Optional. Used to hash the auth cookie. Set a long random string in Vercel.
RAVEN_SESSION_SALT=change-this-random-salt

# Database
# DATABASE_URL=

# Alpaca paper account. Raven 13A is read-only and uses the paper endpoint.
# Supports either ALPACA_* or APCA_* key names.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Later phases
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# AI_PROVIDER_API_KEY=
