# Optional. If set, Raven requires this passcode before showing the dashboard.
RAVEN_ACCESS_KEY=change-this-private-code

# Optional. Used to hash the auth cookie. Set a long random string in Vercel.
RAVEN_SESSION_SALT=change-this-random-salt

